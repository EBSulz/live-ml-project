# Data sources
DATA_SOURCE=twelve_data
TWELVE_DATA_API_KEY=your_twelve_data_key_here
ALPHA_VANTAGE_API_KEY=your_alpha_vantage_key_here
DEFAULT_SYMBOL=BTC/USD
DEFAULT_INTERVAL=1h

# MLflow
MLFLOW_TRACKING_URI=sqlite:///mlflow.db
MLFLOW_EXPERIMENT_NAME=signal-classification-v1
MLFLOW_LIVE_EXPERIMENT_NAME=signal-classification-live
MLFLOW_LOG_INTERVAL=100
MLFLOW_MODEL_NAME=market-predictor

# Model thresholds
MIN_F1_THRESHOLD=0.60
MIN_ACCURACY_THRESHOLD=0.55
DRIFT_WINDOW=500
SIGNAL_THRESHOLD=0.5

# App
APP_ENV=development
LOG_LEVEL=INFO
PORT=8080

# GCP (only needed for cloud deployment)
# GCP_PROJECT_ID=your-project-id
# GCP_REGION=us-central1
# GCS_MODEL_BUCKET=your-project-id-ml-artifacts
# GCS_DVC_BUCKET=your-project-id-dvc-store
# VERTEX_AI_STAGING_BUCKET=
